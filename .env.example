# MongoDB connection for the board app (read by src/db/mongo.ts).
# Next.js auto-loads .env.local for `next dev` / `next build`.
# Copy this file to .env.local and adjust to your setup.

# Connection string for your MongoDB instance.
# In production this points at MongoDB Atlas (a self-hosted VPS Mongo is a
# later swap — only this value changes).
MONGODB_URI=mongodb://127.0.0.1:27017

# Optional: database name. If omitted, the driver uses the URI's db (or "test").
MONGODB_DB=ai_kanban

# HTTP Basic credentials gating the remote MCP route at /api/mcp
# (read by app/api/mcp/route.ts). A single shared credential for the whole
# session pool. Set real values in Vercel / .env.local — never commit secrets.
MCP_BASIC_USER=changeme
MCP_BASIC_PASS=changeme

# Optional: shared secret for the additive `?token=` auth path on /api/mcp
# (read by app/api/mcp/route.ts). A claude.ai cloud routine connector can only
# carry a secret in the URL — it cannot send a custom Authorization header — so
# it authenticates via https://<app>/api/mcp?token=<MCP_URL_TOKEN>. When unset/
# empty the token path is fully disabled and only Basic auth applies. The token
# rides in the URL (may appear in logs) — acceptable for a single-user pool;
# rotate by changing this value and the connector URL.
MCP_URL_TOKEN=changeme
