# Per-card git worktrees of other repos — created at runtime, never tracked
# (these contain nested working trees; tracking them would flood git status)
/workspaces/

# Node
node_modules/
dist/
build/
*.tsbuildinfo

# Env / secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# Next.js
.next/
next-env.d.ts

# orchestrated-feature-dev scratch state (IMPLEMENTATION_PROGRESS.md is kept tracked)
RESEARCH_OUTPUT.md
RESEARCH_FOLLOWUP_*.md
PLAN_STEPS.md
implementation-plan.md
INVESTIGATION_STEP_*.md
VALIDATION_STEP_*.md

# OS / editor
.DS_Store
*.swp
